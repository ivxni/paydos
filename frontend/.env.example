# Copy to .env.local and fill in. On Netlify, set these in
# Site settings -> Environment variables.

# WhatsApp number reservations/contact messages are sent to.
# International format WITHOUT "+" or spaces, e.g. 4915566655128
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Canonical production URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=

# --- Telegram reservation notifications (SERVER-ONLY, never NEXT_PUBLIC) ---
# The /api/reservation endpoint pushes each reservation to this Telegram chat.
# 1) In Telegram, open @BotFather -> /newbot -> copy the token below.
# 2) Start a chat with your new bot (or add it to a group) and send any message.
# 3) Open https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}.
# If these are unset, the form falls back to the customer's WhatsApp (wa.me).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
